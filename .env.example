# TradingView Session Credentials
# Extract these from your browser cookies while logged into tradingview.com
TV_SESSION=your_sessionid_cookie_value_here
TV_SESSION_SIGN=your_sessionid_sign_cookie_value_here

# Default Target Symbol & Timeframe (Optional)
TV_SYMBOL=BINANCE:BTCUSDT
TV_TIMEFRAME=60

# Optional version override (defaults to indicators.local.json mapping or 'last')
# TV_VERSION=last

# Optional indicator input overrides in JSON format (e.g., {"in_9":false})
# TV_INPUTS={}
